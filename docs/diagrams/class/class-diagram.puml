@startuml
title Logical Class Diagram

skinparam classAttributeIconSize 0

class App {
  +startServer()
  +startReminderScheduler()
  +createBot()
}

class BotController {
  +createBot(config, ordersStore)
  +getSystemStatus()
}

class Server {
  +startServer(port, getSystemStatus, whatsappClient, publicDir, ordersStore)
}

class OrdersStore {
  +getAllOrders()
  +getOrdersForUser(phoneNumber)
  +getOrderById(id)
  +saveOrder(order)
  +updateOrder(id, updates)
  +deleteOrder(id)
  +clearAllOrders()
}

class PricingService {
  +calculatePrice(productKey, width, height, quantity)
}

class InvoiceService {
  +generateInvoicePDF(order, filename, docType)
}

class EmailService {
  +sendInvoiceEmail(toEmail, order, pdfPath)
}

class ReminderScheduler {
  +startReminderScheduler(ordersStore, whatsappClient, reminderLogger, getSystemStatus)
}

class ReminderLogger {
  +readReminders()
  +logReminder(entry)
}

class OrderUtils {
  +buildOrderFromCart(...)
  +calculateCartTotals(cart)
  +createSupplyQuote(...)
}

class Order {
  id
  date
  status
  scheduledDate
  scheduleTime
  reminderTime
  reminderSent
  reminderSentAt
  phone
  name
  price
}

class OrderItem {
  product
  quantity
  width
  height
  description
}

App --> BotController
App --> Server
App --> ReminderScheduler
BotController --> OrdersStore
BotController --> PricingService
BotController --> InvoiceService
BotController --> EmailService
BotController --> OrderUtils
Server --> OrdersStore
Server --> InvoiceService
Server --> EmailService
ReminderScheduler --> OrdersStore
ReminderScheduler --> ReminderLogger
OrdersStore "1" o-- "0..*" Order
Order "1" *-- "1..*" OrderItem

note bottom of BotController
The implementation uses CommonJS modules and exported
functions rather than ES6 classes. This diagram models
the logical service responsibilities of those modules.
end note

@enduml
